#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  ./run ctrl
  ./run offline
  ./run online

Examples:
  ./run ctrl
  ./run offline -- -test
EOF
}

if [ "$#" -lt 1 ]; then
  usage
  exit 1
fi

service="$1"
shift

case "$service" in
  ctrl|control)
    cd "$ROOT_DIR/control"
    exec go run ./cmd/control "$@"
    ;;
  offline)
    cd "$ROOT_DIR/offline"
    exec go run ./cmd/offline "$@"
    ;;
  online)
    cd "$ROOT_DIR/online"
    exec go run ./cmd/online "$@"
    ;;
  *)
    echo "unknown service: $service" >&2
    usage
    exit 1
    ;;
esac
